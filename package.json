{
  "name": "catalyst-stream-controller",
  "productName": "Catalyst Stream Controller",
  "version": "0.0.0",
  "description": "Open-source stream controller configuration tool for Razer Stream Controller X, Loupedeck, and more",
  "main": ".vite/build/index.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "tsc --noEmit",
    "check": "svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
    "deadcode": "knip --include files --include unlisted --include dependencies",
    "test": "vitest run --reporter=dot",
    "test:watch": "vitest",
    "test:unit": "vitest run --config vitest.config.ts --reporter=dot",
    "test:components": "vitest run --config vitest.config.renderer.ts --reporter=dot",
    "test:coverage": "vitest run --coverage",
    "validate": "npm run typecheck && npm run check && npm run lint:fix && npm run deadcode && npm run test && npm run test:components",
    "generate-icons": "node build/generate-icons.js"
  },
  "keywords": [
    "stream-controller",
    "razer",
    "loupedeck",
    "electron",
    "stream-deck"
  ],
  "author": {
    "name": "Dzuelu"
  },
  "license": "MIT",
  "overrides": {
    "node-addon-api": "^8.6.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^9.39.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "electron": "40.4.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-svelte": "^3.15.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "knip": "^5.84.1",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "svelte": "^5.51.3",
    "svelte-check": "^4.4.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.56.0",
    "vite": "^6.4.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@elgato-stream-deck/node": "^7.5.2",
    "canvas": "^3.2.1",
    "electron-squirrel-startup": "^1.0.1",
    "node-hid": "^3.3.0",
    "obs-websocket-js": "^5.0.7",
    "qrcode": "^1.5.4",
    "serialport": "^13.0.0",
    "ws": "^8.19.0"
  }
}
